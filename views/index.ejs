<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= storeName %></title>

<style>
body{
background:#0f0f0f;
color:white;
font-family:sans-serif;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
margin:0;
}

.card{
background:#1a1a1a;
padding:40px;
border-radius:20px;
text-align:center;
box-shadow:0 0 30px rgba(0,0,0,.5);
}

h1{
font-size:50px;
margin-bottom:10px;
color:#8b5cf6;
}

p{
opacity:.8;
}
</style>
</head>

<body>

<div class="card">
<h1><%= storeName %></h1>
<p>Website Online Successfully</p>
</div>

</body>
</html>
